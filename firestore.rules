rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// PAD V2 — Regras de segurança do Firestore (esqueleto — Fase 0)
//
// Princípio: negar por padrão, liberar explicitamente por perfil autenticado.
// A matriz completa de permissões por perfil/ação será implementada na Fase 1
// (ver ROADMAP.md). Nesta fase as regras apenas garantem que:
//   - nenhum acesso anônimo é permitido;
//   - um usuário só lê/escreve o próprio documento em `usuarios`;
//   - demais coleções institucionais exigem autenticação (leitura) e ficam
//     fechadas para escrita até a Fase 1 definir a matriz de perfis.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function ehDonoDoDocumento(userId) {
      return autenticado() && request.auth.uid == userId;
    }

    function meuUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function tenhoPerfil() {
      return autenticado() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function souAdministrador() {
      return tenhoPerfil() && meuUsuario().perfil == 'ADMINISTRADOR';
    }

    // Direção/CPEN de uma unidade, OU Superintendência Regional (todas as
    // unidades da sua regional) — únicos, além do Administrador, que podem
    // gerenciar solicitações/Servidores daquele alvo (ver
    // docs/firestore-schema.md e src/pages/usuarios/usuariosPage.js).
    // `dadosAlvo` é o documento sendo lido/alterado — usa `unidadeSolicitada`
    // enquanto PENDENTE e `unidade`/`superintendencia` depois de ATIVO (os
    // dois últimos setados desde o autocadastro, ver src/services/auth).
    function souGestorDoAlvo(dadosAlvo) {
      return tenhoPerfil() && meuUsuario().perfil == 'DIRETOR' && (
        (meuUsuario().vinculo.tipo == 'UNIDADE' && (
          meuUsuario().vinculo.valor == dadosAlvo.unidadeSolicitada || meuUsuario().vinculo.valor == dadosAlvo.unidade
        ))
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosAlvo.superintendencia)
      );
    }

    // Um gestor (não-Administrador) só pode conceder estes perfis a um
    // Servidor — nunca Diretor/Administrador, para não criar um superior ou
    // um par dentro da própria unidade/regional por essa tela.
    function perfilPermitidoParaGestor(perfilNovo) {
      return perfilNovo in ['SERVIDOR', 'CONSELHO_DISCIPLINAR', 'SUBDIRETOR'];
    }

    // Quem pode criar um PAD (tela "Novo PAD", ver
    // src/pages/pad/new/padNewPage.js e src/services/pads/padService.js):
    // Administrador cria para qualquer unidade; vínculo UNIDADE só para a
    // própria unidade; vínculo REGIONAL só para unidades da própria SR
    // (campo `superintendencia`, no topo do documento, denormalizado a
    // partir da unidade — mesma estratégia do campo homônimo em `usuarios`,
    // ver docs/firestore-schema.md). `dadosPad` é o documento inteiro (tem
    // `dadosGerais.unidade` e `superintendencia`).
    function souCriadorDoPad(dadosPad) {
      return tenhoPerfil() && meuUsuario().perfil in ['ADMINISTRADOR', 'DIRETOR', 'SUBDIRETOR', 'SERVIDOR'] && (
        meuUsuario().perfil == 'ADMINISTRADOR'
        || (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosPad.dadosGerais.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosPad.superintendencia)
      );
    }

    // Só Direção/CPEN (perfil DIRETOR — os dois usam o mesmo perfil, ver
    // docs/permissions-matrix.md) da própria unidade/regional, ou
    // Administrador, podem excluir um PAD da relação — nunca um Servidor,
    // mesmo que tenha sido quem o criou.
    function souGestorDoPad(dadosPad) {
      return tenhoPerfil() && meuUsuario().perfil == 'DIRETOR' && (
        (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosPad.dadosGerais.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosPad.superintendencia)
      );
    }

    // Leitura de um PAD (2026-07-19, auditoria de segurança) — igual a
    // `souCriadorDoPad`, mas SEM a restrição de perfil, porque Conselho
    // Disciplinar também precisa ler PADs da própria unidade (só não pode
    // criar/editar). Antes desta função, `pads.allow read` usava só
    // `tenhoPerfil()` (qualquer conta institucional, de qualquer unidade) —
    // vazava leitura entre unidades.
    function souInstitucionalNoEscopoDoPad(dadosPad) {
      return tenhoPerfil() && (
        meuUsuario().perfil == 'ADMINISTRADOR'
        || (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosPad.dadosGerais.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosPad.superintendencia)
      );
    }

    // Um PAD atualizado (Fase 2, 2026-07-14) não pode ser "movido" para outra
    // unidade/regional por essa via — só o escopo com que ele nasceu.
    function identidadeInalterada(antes, depois) {
      return depois.dadosGerais.unidade == antes.dadosGerais.unidade
        && depois.superintendencia == antes.superintendencia;
    }

    // Gestão da configuração por unidade (Conselho Disciplinar/Diretor,
    // coleção `configuracoesUnidade`) — Direção OU Subdiretor da própria
    // unidade/regional (tarefa administrativa rotineira, por isso inclui
    // Subdiretor, diferente de `souGestorDoPad` que é só Diretor).
    function souGestorDeConfigUnidade(dadosConfig) {
      return tenhoPerfil() && meuUsuario().perfil in ['DIRETOR', 'SUBDIRETOR'] && (
        (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosConfig.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosConfig.superintendencia)
      );
    }

    // Coleção de contas institucionais (Administrador, Diretor, Subdiretor,
    // Servidor, Conselho Disciplinar, Defensor Público). Autocadastro
    // (Fase 1, 2026-07-14): qualquer pessoa autenticada pode criar o PRÓPRIO
    // documento com status PENDENTE (nunca definindo `perfil` nessa escrita —
    // só a aprovação define o perfil). Depois de ATIVO, um gestor só
    // lê/edita/exclui alvos com `perfil == 'SERVIDOR'` — nunca outro
    // Diretor/CPEN/Regional/Administrador.
    match /usuarios/{userId} {
      allow read: if ehDonoDoDocumento(userId)
        || souAdministrador()
        || (resource.data.status == 'PENDENTE' && souGestorDoAlvo(resource.data))
        || (resource.data.status == 'ATIVO' && resource.data.perfil == 'SERVIDOR' && souGestorDoAlvo(resource.data));

      allow create: if ehDonoDoDocumento(userId)
        && request.resource.data.status == 'PENDENTE'
        && !('perfil' in request.resource.data);

      allow update: if souAdministrador()
        || (resource.data.status == 'PENDENTE' && souGestorDoAlvo(resource.data)
            && perfilPermitidoParaGestor(request.resource.data.perfil))
        || (resource.data.status == 'ATIVO' && resource.data.perfil == 'SERVIDOR' && souGestorDoAlvo(resource.data)
            && perfilPermitidoParaGestor(request.resource.data.perfil));

      allow delete: if souAdministrador()
        || (resource.data.status == 'PENDENTE' && souGestorDoAlvo(resource.data))
        || (resource.data.status == 'ATIVO' && resource.data.perfil == 'SERVIDOR' && souGestorDoAlvo(resource.data));
    }

    // Contas do Portal da Defesa — contexto de autenticação separado do
    // painel institucional (Fase 6, 2026-07-19). `defensorId` = uid da conta
    // de Firebase Auth do defensor (advogado constituído ou defensor
    // público) — ver src/services/defensores/defensorService.js.
    function tenhoPerfilDefensor() {
      return autenticado() && exists(/databases/$(database)/documents/defensores/$(request.auth.uid));
    }

    function meuDefensor() {
      return get(/databases/$(database)/documents/defensores/$(request.auth.uid)).data;
    }

    // Usado pela regra de `pads` abaixo — o defensor só lê/edita PADs em que
    // está vinculado (`padsVinculados`) e com a conta ativa.
    function souDefensorVinculado(padId) {
      return tenhoPerfilDefensor() && padId in meuDefensor().padsVinculados && meuDefensor().ativo == true;
    }

    // `padsVinculados` só muda de duas formas na aplicação real (ver
    // src/services/defensores/defensorService.js): `vincularDefensorAoPad`
    // sempre ACRESCENTA um `padId` no fim (via
    // `Array.from(new Set([...existentes, padId]))`, que preserva ordem de
    // inserção); `desvincularDefensorDoPad` sempre REMOVE um `padId` via
    // `filter` (de qualquer posição do array).
    function souInstitucionalNoEscopoDeVincularDefensor() {
      return souCriadorDoPad(get(/databases/$(database)/documents/pads/$(request.resource.data.padsVinculados[request.resource.data.padsVinculados.size() - 1])).data);
    }

    match /defensores/{defensorId} {
      allow read: if ehDonoDoDocumento(defensorId) || tenhoPerfil();
      // Criar o vínculo/conta é parte de preencher o Termo de Cientificação
      // — mesmo escopo de quem já edita o PAD (ver `pads` abaixo).
      allow create: if tenhoPerfil();
      // `padsVinculados` (2026-07-19, auditoria de segurança): antes disso,
      // QUALQUER conta institucional podia adicionar ou remover QUALQUER
      // `padId` de QUALQUER defensor — um vazamento indireto (concede acesso
      // de defensor a PAD de outra unidade sem nenhum vínculo real com ele).
      // Agora: ADICIONAR (vincular) exige que quem grava esteja no escopo
      // do PAD sendo vinculado (mesmo escopo de quem edita o PAD).
      // REMOVER (revogar) fica restrito a Diretor/CPEN (perfil `DIRETOR`) ou
      // Administrador — mais amplo que o ideal (não confirma que é
      // especificamente o Diretor/CPEN *daquela* unidade, já que a regra não
      // consegue identificar de forma confiável qual elemento do array foi
      // removido sem iterar posição a posição, algo que a linguagem de
      // regras do Firestore não permite de forma genérica) — ainda assim já
      // fecha a maior parte da exposição (Servidor/Subdiretor/Conselho não
      // conseguem mais revogar acesso de defensor nenhum). Documentado como
      // limitação conhecida, não solução completa — ver auditoria
      // 2026-07-19. `ativo` (kill-switch da conta inteira) continua só
      // Administrador. `atualizadoEm` sempre vem junto (repositório genérico
      // grava em toda escrita, ver firestoreRepository.js).
      allow update: if tenhoPerfil() && (
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['padsVinculados', 'atualizadoEm'])
          && (
            // Sem mudança real de conteúdo (reenvio idempotente — ex.:
            // "Criar acesso" clicado de novo pra um defensor já vinculado a
            // este mesmo PAD) — nada a autorizar, o conjunto continua igual.
            request.resource.data.padsVinculados.toSet() == resource.data.padsVinculados.toSet()
            || (
              request.resource.data.padsVinculados.size() > resource.data.padsVinculados.size()
              && souInstitucionalNoEscopoDeVincularDefensor()
            )
            || (
              request.resource.data.padsVinculados.size() < resource.data.padsVinculados.size()
              && (souAdministrador() || meuUsuario().perfil == 'DIRETOR')
            )
          )
        )
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ativo', 'atualizadoEm']) && souAdministrador())
      );
    }

    // PAD (Fase 2, 2026-07-14). Criação: numeração+unidade+status inicial.
    // Atualização: preenchimento progressivo dos documentos do PAD (Portaria,
    // Termo de Cientificação, Testemunhas, Conselho, Defesa, Decisão,
    // Ofícios — ver docs/firestore-schema.md) por quem está no escopo de
    // criação do PAD; cada aba grava sempre o objeto aninhado inteiro dela
    // (nunca um sub-campo em notação de ponto — ver
    // src/pages/pad/detail/documentos). Validação formal de transição de
    // etapa (máquina de estados completa) fica para depois — aqui só
    // garantimos que a identidade (unidade/regional) do PAD não muda e que
    // `status` continua um valor válido do enum.
    match /pads/{padId} {
      // Leitura escopada por unidade/regional (2026-07-19, auditoria de
      // segurança) — antes disso, qualquer conta institucional lia qualquer
      // PAD de qualquer unidade (`tenhoPerfil()` sozinho não olha `vinculo`).
      // Um defensor só vê os PADs em que está vinculado (sem isto, qualquer
      // conta de defensor conseguiria ler PADs alheios).
      allow read: if souInstitucionalNoEscopoDoPad(resource.data) || souDefensorVinculado(padId);
      allow create: if souCriadorDoPad(request.resource.data)
        && request.resource.data.status == 'EM_ANDAMENTO';
      allow update: if (
          souCriadorDoPad(resource.data)
          && souCriadorDoPad(request.resource.data)
          && identidadeInalterada(resource.data, request.resource.data)
          && request.resource.data.status in ['EM_ANDAMENTO', 'AGUARDANDO_DEFESA', 'AGUARDANDO_DECISAO', 'CONCLUIDO', 'ARQUIVADO']
        ) || (
          // Manifestação da Defesa enviada pelo próprio Portal da Defesa —
          // só o campo `defesa` (mais `atualizadoEm`, que o repositório
          // genérico sempre grava junto, ver firestoreRepository.js), e só
          // enquanto a Unidade ainda não confirmou/fechou esse documento.
          souDefensorVinculado(padId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['defesa', 'atualizadoEm'])
          && (!('confirmacoes' in resource.data) || !('defesa' in resource.data.confirmacoes) || resource.data.confirmacoes.defesa.confirmado != true)
        );
      allow delete: if souAdministrador() || souGestorDoPad(resource.data);
    }

    // Leitura de um evento (2026-07-19, auditoria de segurança) — `eventos`
    // agora grava `unidade`/`superintendencia` denormalizados (mesma
    // convenção já usada em `pads.superintendencia`/`usuarios.superintendencia`)
    // no momento da criação, então a checagem de escopo é direta no próprio
    // documento — sem precisar de `get()` no PAD referenciado (o que também
    // evita quebrar a leitura de eventos órfãos, de PAD já excluído, para
    // quem já tinha escopo sobre eles). Antes, `allow read: if autenticado()`
    // liberava QUALQUER sessão autenticada — inclusive defensor do Portal da
    // Defesa e autocadastro ainda PENDENTE — a ler o histórico de eventos de
    // todos os PADs do Estado.
    function souInstitucionalNoEscopoDoEvento(dadosEvento) {
      return tenhoPerfil() && (
        meuUsuario().perfil == 'ADMINISTRADOR'
        || (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosEvento.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosEvento.superintendencia)
      );
    }

    // Evento lançado junto com o preenchimento de uma etapa do PAD (ver
    // src/pages/pad/new/padNewPage.js e src/pages/pad/detail/documentos) —
    // autorização de criação/exclusão espelha a do próprio PAD referenciado
    // por `padId` (via `get()`); leitura usa os campos denormalizados no
    // próprio evento (ver acima). Exclusão só em cascata com o PAD (ver
    // `excluirPad` em padService.js — os eventos são removidos ANTES do PAD,
    // enquanto `get()` ainda o encontra) e só por quem poderia excluir o
    // próprio PAD.
    match /eventos/{eventoId} {
      allow read: if souInstitucionalNoEscopoDoEvento(resource.data) || souDefensorVinculado(resource.data.padId);
      allow create: if souCriadorDoPad(get(/databases/$(database)/documents/pads/$(request.resource.data.padId)).data);
      allow delete: if souAdministrador() || souGestorDoPad(get(/databases/$(database)/documents/pads/$(resource.data.padId)).data);
      allow update: if false;
    }

    match /logs/{logId} {
      allow read: if false; // logs são consultados via ferramentas administrativas
      allow create: if autenticado();
      allow update, delete: if false; // logs são imutáveis
    }

    match /configuracoes/{configId} {
      allow read: if autenticado();
      allow write: if false;
    }

    // Relação de Advogados (2026-07-19) — diretório de contato institucional,
    // pré-importado de uma planilha real do i-PEN (ver docs/firestore-schema.md).
    // Independente do Portal da Defesa (`defensores`): existe pra qualquer
    // advogado conhecido, tenha ele vínculo ativo a algum PAD ou não. Chave =
    // OAB. Sem restrição fina por campo — é um diretório de contato que
    // qualquer conta institucional pode completar/corrigir.
    match /advogadosCadastro/{oab} {
      allow read: if tenhoPerfil();
      allow create: if tenhoPerfil();
      allow update: if tenhoPerfil();
    }

    // Conselho Disciplinar/Diretor(a) por unidade (Fase 2, 2026-07-14) — id do
    // documento é o nome da unidade. Reaproveitado como valor inicial (cópia,
    // não referência viva) ao preencher a Portaria/Conselho/Decisão de um
    // PAD — ver docs/firestore-schema.md.
    match /configuracoesUnidade/{unidadeId} {
      allow read: if autenticado();
      allow create, update: if souAdministrador() || souGestorDeConfigUnidade(request.resource.data);
      allow delete: if souAdministrador();
    }

    match /modelos/{modeloId} {
      allow read: if autenticado();
      allow write: if false;
    }

    // Lembretes (2026-07-20) — quadro de anotações livres por unidade, no
    // lugar da antiga Timeline de atividades do Dashboard. Mesmo escopo de
    // leitura/escrita de `eventos`/`pads` (conta institucional no escopo da
    // unidade/regional do lembrete) — qualquer uma pode criar/marcar como
    // feito/excluir, não só quem criou (é um quadro de equipe, não pessoal).
    function souInstitucionalNoEscopoDoLembrete(dadosLembrete) {
      return tenhoPerfil() && (
        meuUsuario().perfil == 'ADMINISTRADOR'
        || (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosLembrete.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosLembrete.superintendencia)
      );
    }

    match /lembretes/{lembreteId} {
      allow read: if souInstitucionalNoEscopoDoLembrete(resource.data);
      allow create: if souInstitucionalNoEscopoDoLembrete(request.resource.data);
      // Update só pode mudar `feito` (marcar/desmarcar) — o texto do
      // lembrete é imutável depois de criado, mesmo espírito de mensagem.
      allow update: if souInstitucionalNoEscopoDoLembrete(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feito', 'atualizadoEm']);
      allow delete: if souInstitucionalNoEscopoDoLembrete(resource.data);
    }

    // Mensagens entre a Unidade e o(a) defensor(a) vinculado a um PAD
    // (2026-07-20) — thread por PAD, sem edição/exclusão (log de conversa).
    // Mesmo escopo de leitura de `eventos`: conta institucional no escopo do
    // PAD (via campos denormalizados) OU o defensor vinculado àquele PAD
    // (`souDefensorVinculado`, definida acima). Criação exige que
    // `autorUid` seja de quem está autenticado e que `autorTipo` bata com o
    // tipo de conta de quem está criando — evita que um lado se passe pelo
    // outro na própria mensagem.
    function souInstitucionalNoEscopoDaMensagem(dadosMensagem) {
      return tenhoPerfil() && (
        meuUsuario().perfil == 'ADMINISTRADOR'
        || (meuUsuario().vinculo.tipo == 'UNIDADE' && meuUsuario().vinculo.valor == dadosMensagem.unidade)
        || (meuUsuario().vinculo.tipo == 'REGIONAL' && meuUsuario().vinculo.valor == dadosMensagem.superintendencia)
      );
    }

    match /mensagens/{mensagemId} {
      allow read: if souInstitucionalNoEscopoDaMensagem(resource.data) || souDefensorVinculado(resource.data.padId);
      allow create: if request.resource.data.autorUid == request.auth.uid && (
        (request.resource.data.autorTipo == 'institucional' && souInstitucionalNoEscopoDaMensagem(request.resource.data))
        || (request.resource.data.autorTipo == 'defensor' && souDefensorVinculado(request.resource.data.padId))
      );
      allow update, delete: if false;
    }

    // Qualquer coleção não mapeada explicitamente permanece bloqueada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
